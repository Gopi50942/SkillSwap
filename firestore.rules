// firestore.rules  –  SkillSwap security rules
// Deploy: firebase deploy --only firestore:rules

rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── Helper: is caller authenticated? ──────────────────────
    function isAuth() {
      return request.auth != null;
    }
    function isOwner(uid) {
      return isAuth() && request.auth.uid == uid;
    }
    function isParticipant(data) {
      return isAuth() && request.auth.uid in data.participants;
    }

    // ── users ──────────────────────────────────────────────────
    // Anyone logged in can read profiles (needed for matching/discover).
    // Only the owner can write their own profile.
    match /users/{uid} {
      allow read:  if isAuth();
      allow create: if isOwner(uid);
      allow update: if isOwner(uid)
        // Prevent self-manipulating rating/sessionsCount directly
        || (isAuth()
            && request.resource.data.diff(resource.data).affectedKeys()
               .hasOnly(['rating','ratingCount','sessionsCount','badges']));
      allow delete: if isOwner(uid);
    }

    // ── matches ────────────────────────────────────────────────
    // Only participants can read/update their match.
    // Any authenticated user can create a match (the matchId enforces uniqueness).
    match /matches/{matchId} {
      allow read:   if isParticipant(resource.data);
      allow create: if isAuth()
        && request.auth.uid in request.resource.data.participants;
      allow update: if isParticipant(resource.data);
      allow delete: if false;
    }

    // ── sessions ───────────────────────────────────────────────
    match /sessions/{sessionId} {
      allow read:   if isParticipant(resource.data);
      allow create: if isAuth()
        && request.auth.uid in request.resource.data.participants;
      allow update: if isParticipant(resource.data);
      allow delete: if false;
    }

    // ── reviews ────────────────────────────────────────────────
    // Anyone logged in can read reviews (shown on public profiles).
    // Only the reviewer (fromUid) can write; one review per session.
    match /reviews/{reviewId} {
      allow read:   if isAuth();
      allow create: if isAuth()
        && request.auth.uid == request.resource.data.fromUid
        && request.resource.data.rating is number
        && request.resource.data.rating >= 1
        && request.resource.data.rating <= 5;
      allow update: if false;
      allow delete: if false;
    }
  }
}
